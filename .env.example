# Server
PORT=3000
BASE_URL=http://localhost:3000

# ─── Authentication ───
# Shared password for the team dashboard
TEAM_ACCESS_CODE=winningcircle-dev

# ─── JWT Session ───
# Generate a strong random secret: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=replace-with-a-strong-random-secret


# ─── Database (choose one) ───

# Option A: Turso (cloud SQLite — recommended for Vercel)
# Sign up free at https://turso.tech
TURSO_DATABASE_URL=libsql://your-db-name-your-org.turso.io
TURSO_AUTH_TOKEN=your-auth-token

# Option B: Local SQLite (default for local dev)
# DB_PATH=./dashboard.db

# ─── Slack Integration ───
# Get these from https://api.slack.com/apps
SLACK_BOT_TOKEN=xoxb-your-bot-token
SLACK_SIGNING_SECRET=your-signing-secret
SLACK_CHANNEL_ID=C01ABCDEFGH

# Reminder schedule (cron format, default: weekdays at 9am)
REMINDER_CRON=0 9 * * 1-5
